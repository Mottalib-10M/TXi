generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum BookingStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
  COMPLETED
}

enum SharedRouteStatus {
  PENDING_DRIVER
  ACTIVE
  FULL
  DEPARTED
  CANCELLED
}

enum PassengerStatus {
  CONFIRMED
  CANCELLED
}

enum LuggageType {
  NONE
  SMALL
  LARGE
}

enum BookingSource {
  LANDING
  PROFILE
  ORGANIZATION
}

enum OrgType {
  HOTEL
  HOSPITAL
  ENTERPRISE
  INDIVIDUAL
}

model Driver {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  firstName    String
  lastName     String
  slug         String   @unique
  phone        String   @default("")
  photoUrl     String?
  bio          String?
  companyName  String?

  // Vehicle (flat fields = vehicle 1, kept for backward compat)
  vehicleBrand    String?
  vehicleModel    String?
  vehicleYear     Int?
  vehicleColor    String?
  vehiclePlate    String?
  vehicleCapacity Int      @default(4)
  vehicleFeatures String[] @default([])

  // Multi-vehicle support (JSON array of Vehicle objects, max 2)
  vehicles Json?

  // Coverage zone
  zoneLat     Float?
  zoneLng     Float?
  zoneRadius  Float    @default(15)
  zoneAddress String?

  // Pricing (defaults = plafonds réglementaires 2026, service-public.gouv.fr)
  baseFare           Float @default(4.48)
  pricePerKm         Float @default(1.30)
  pricePerKmNight    Float @default(1.30)
  pricePerMinute     Float @default(0.70)
  minimumFare        Float @default(8.0)
  airportSupplement  Float @default(4.0)
  nightSupplement    Float @default(0.0)
  customPrices       Json?

  // Availability (JSON: array of { day: 0-6, startTime: "HH:mm", endTime: "HH:mm" })
  availability Json?

  // Notification preferences
  notifyEmail Boolean @default(true)
  notifySms   Boolean @default(false)

  // Status
  isActive      Boolean @default(true)
  isVerified    Boolean @default(false)
  emailVerified Boolean @default(false)

  // Activity tracking
  lastLoginAt DateTime?
  loginCount  Int       @default(0)

  bookings     Booking[]
  favoritedBy  FavoriteDriver[]
  sharedRoutes SharedRoute[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("drivers")
}

model Booking {
  id        String @id @default(cuid())
  reference String @unique

  // Client info
  clientName     String
  clientEmail    String
  clientPhone    String   @default("")
  clientComments String?

  // Departure
  departureName String
  departureLat  Float
  departureLng  Float

  // Arrival
  arrivalName String
  arrivalLat  Float
  arrivalLng  Float

  // Trip details
  requestedDate     DateTime
  passengerCount    Int          @default(1)
  estimatedDistance  Float?
  estimatedDuration Float?
  estimatedPrice    Float?

  // Tarif fixe garanti (figé à la création, ne change plus)
  lockedPrice Float?

  // Status
  status BookingStatus @default(PENDING)
  source BookingSource @default(LANDING)

  // Escalation
  escalationPhase  Int       @default(0)   // 0=initial, 1=escalated, 2=admin notified
  escalatedAt      DateTime?
  invitedDriverIds String[]  @default([])

  // Driver relation
  driver   Driver? @relation(fields: [driverId], references: [id])
  driverId String?

  // Organisation (optionnel - null = booking direct client)
  organization   Organization? @relation(fields: [organizationId], references: [id])
  organizationId String?

  // Nom du bénéficiaire (patient, client hôtel, salarié)
  beneficiaryName String?

  // Cagnotte link
  cagnotteTransaction CagnotteTransaction?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("bookings")
}

model Organization {
  id           String  @id @default(cuid())
  email        String  @unique
  passwordHash String
  name         String
  type         OrgType
  contactName  String
  phone        String  @default("")
  address      String?

  // Cagnotte (5% des courses complétées)
  cagnotteBalance Float @default(0)

  emailVerified Boolean @default(false)

  // Activity tracking
  lastLoginAt DateTime?
  loginCount  Int       @default(0)

  bookings        Booking[]
  favoriteDrivers FavoriteDriver[]
  cagnotteHistory CagnotteTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("organizations")
}

model FavoriteDriver {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  driver         Driver       @relation(fields: [driverId], references: [id])
  driverId       String
  createdAt      DateTime     @default(now())

  @@unique([organizationId, driverId])
  @@map("favorite_drivers")
}

model CagnotteTransaction {
  id             String       @id @default(cuid())
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  booking        Booking      @relation(fields: [bookingId], references: [id])
  bookingId      String       @unique
  amount         Float
  createdAt      DateTime     @default(now())

  @@map("cagnotte_transactions")
}

model SharedRoute {
  id                  String            @id @default(cuid())
  driver              Driver?           @relation(fields: [driverId], references: [id])
  driverId            String?
  proposerName        String?
  proposerEmail       String?
  proposerPhone       String?
  departureLocationId String
  departureName       String
  departureLat        Float
  departureLng        Float
  destinationName     String
  destinationLat      Float
  destinationLng      Float
  departureTime       DateTime
  totalSeats          Int
  status              SharedRouteStatus @default(ACTIVE)
  passengers          SharedRoutePassenger[]
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@map("shared_routes")
}

model SharedRoutePassenger {
  id              String          @id @default(cuid())
  sharedRoute     SharedRoute     @relation(fields: [sharedRouteId], references: [id])
  sharedRouteId   String
  passengerName   String
  passengerEmail  String
  passengerPhone  String          @default("")
  seatCount       Int             @default(1)
  luggageType     LuggageType     @default(NONE)
  status          PassengerStatus @default(CONFIRMED)
  createdAt       DateTime        @default(now())

  @@map("shared_route_passengers")
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  token     String   @unique
  email     String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  email     String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("password_reset_tokens")
}
